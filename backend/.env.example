# REITs数据平台 - 环境变量配置

# 应用配置
DEBUG=false
HOST=0.0.0.0
PORT=3001

# 数据库（复用现有SQLite）
DATABASE_URL=sqlite:///./database/reits.db

# JWT密钥（生产环境必须修改！）
JWT_SECRET=your-super-secret-key-change-this-in-production

# 管理员默认密码（首次启动后建议修改）
DEFAULT_ADMIN_PASSWORD=admin123

# 爬虫配置
CRAWLER_ENABLED=true

# AI配置（可选）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
