# REITs数据平台 - 环境变量配置

# 应用配置
DEBUG=false
HOST=0.0.0.0
# 注意：PORT环境变量会影响api_adapter.py的监听端口
# 如需修改API端口，请直接修改api_adapter.py
# PORT=3001

# 数据库（复用现有SQLite）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_db

# JWT密钥（生产环境必须修改！）
JWT_SECRET=your-super-secret-key-change-this-in-production

# 管理员默认密码（首次启动后建议修改）
DEFAULT_ADMIN_PASSWORD=admin123

# 爬虫配置
CRAWLER_ENABLED=true

# AI配置
DEEPSEEK_API_KEY=sk-f5dcc16439f144f9abf5d1af7f992a39
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# we-mp-rss 源数据库（SQLite本地路径）
WEMP_SOURCE_DB=./scripts/we_mp_rss_source.db

# Milvus 向量数据库（Lite 本地文件模式）

# Embedding 配置（local=本地sklearn，无需网络）

# Milvus 向量数据库（Lite 本地文件模式）
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=reit_wechat_articles

# Embedding 配置（local=本地sklearn，无需网络）
EMBEDDING_PROVIDER=local
EMBEDDING_DIMENSION=256
