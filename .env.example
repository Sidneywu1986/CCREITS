# ============================================================
# CCREITS 环境变量配置模板
# 复制为 .env 后按需修改
# ============================================================

# ------------------
# 基础配置
# ------------------
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ------------------
# 数据库配置 (PostgreSQL)
# ------------------
# v3.0 起主业务库与 AI 库统一使用 PostgreSQL，通过 schema 隔离
# 旧 SQLite 路径保留兼容：DB_TYPE=sqlite 时启用
DB_TYPE=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reits
SQLITE_PATH=./database/reits.db

# PostgreSQL 统一参数（asyncpg / psycopg2 共用）
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=reits

# ------------------
# 安全
# ------------------
JWT_SECRET=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ------------------
# 爬虫
# ------------------
CRAWLER_ENABLED=true
CRAWLER_SCHEDULER_ENABLED=true
CRAWLER_SCHEDULER_INTERVAL=3600
AKSHARE_TIMEOUT=30
CNINFO_TIMEOUT=10
CNINFO_RETRY_TIMES=3

# ------------------
# AI / LLM
# ------------------
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=

# ------------------
# Embedding / 向量
# ------------------
EMBEDDING_PROVIDER=zhipu
EMBEDDING_API_KEY=
EMBEDDING_MODEL=embedding-3
EMBEDDING_BATCH_SIZE=100

# ------------------
# Milvus 向量数据库
# ------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# ------------------
# 日志
# ------------------
LOG_LEVEL=INFO
